<?xml version="1.0"?>
<model>
  <name>RobotX 2026 Singapore River Course</name>
  <version>1.0.0</version>
  <sdf version="1.11">model.sdf</sdf>
  <author>
    <name>BumblebeeAS</name>
    <email>bumblebee.auv@gmail.com</email>
  </author>
  <description>Competition course terrain for RobotX 2026 at Singapore River, Marina Bay. Includes Fuel-hosted terrain mesh, drone landing platform collision, and jetty collision box. Coast Water surface and visual piers must be included at the world level (Fuel models with ShaderParam plugins or material refs cannot be safely nested inside another model's include).</description>
</model>

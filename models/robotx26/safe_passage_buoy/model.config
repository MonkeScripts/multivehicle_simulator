<?xml version="1.0"?>
<model>
  <name>safe_passage_buoy</name>
  <version>1.0</version>
  <sdf version="1.9">model.sdf</sdf>
  <author>
    <name>bumblebeeAS</name>
    <email>bumblebeeauv@gmail.com</email>
  </author>
  <description>RobotX 2026 Safe Passage LED buoy. A sphere bulb whose emissive colour the gz_led_plugin LedPlugin sets per mode (solid self-lit colour, all angles, no reflected light) via /led_&lt;instance&gt;/change_led_mode. Note: runtime emissive updates don't re-render in this Gazebo build, so flash_* modes appear solid (don't blink); steady_*/off behave normally. Replaces the old teleport-based led_beacon set.</description>
</model>
